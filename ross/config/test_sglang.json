{
    "backend": ["sglang"],
    "platforms": [{"gpu": "H200", "version": "0.5.6"}],
    "model": ["Meta-Llama-3.1-70B"],
    "mode": "online",
    "parallel": ["1:1:8", "1:1:4@1:1:4"],
    "batch": [256],
    "num_prompt": 512,
    "inputs": ["sharegpt@500_2500"],
    "output": "~/.etc",
    "datapath": "~/.etc",
    "ross_extra": [
        {
            "backend": "sglang",
            "num_gpus": 8,
            "mem_fraction_static": [0.9]
        }
    ],
    "override":   false,
    "quiet":      false,
    "validation": false
}